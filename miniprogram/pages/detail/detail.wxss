.container {
  padding: 24rpx;
  min-height: 100vh;
}

.unlock-badge {
  text-align: center;
  font-size: 28rpx;
  color: #FAAD14;
  font-weight: 600;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-row:last-child { border-bottom: none; }

.detail-label {
  font-size: 28rpx;
  color: #666;
}

.detail-val {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.detail-val.highlight {
  color: #1677FF;
  font-size: 36rpx;
  font-weight: 700;
}

.extra-row, .gap-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.extra-row:last-child, .gap-row:last-child { border-bottom: none; }

.extra-label, .gap-label {
  font-size: 28rpx;
  color: #666;
}

.extra-right, .gap-right {
  text-align: right;
}

.extra-amount {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #52C41A;
}

.extra-annual {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.gap-amount {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #FF4D4F;
}

.gap-pct {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.gap-tip {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 16rpx;
}

.share-btn {
  width: 100%;
  height: 88rpx;
  background: #1677FF;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  margin-bottom: 16rpx;
}

.recalc-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #1677FF;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid #1677FF;
  margin-bottom: 40rpx;
}
