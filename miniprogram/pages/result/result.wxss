.container {
  padding: 24rpx;
  min-height: 100vh;
}

.result-card {
  background: linear-gradient(135deg, #1677FF, #0050D0);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  color: #fff;
  margin-bottom: 24rpx;
}

.result-label {
  display: block;
  font-size: 28rpx;
  opacity: 0.85;
  margin-bottom: 16rpx;
}

.result-amount {
  display: block;
  font-size: 80rpx;
  font-weight: 700;
  letter-spacing: -2rpx;
}

.result-sub {
  display: block;
  font-size: 26rpx;
  opacity: 0.8;
  margin-top: 12rpx;
}

.result-meta {
  margin-top: 20rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 40rpx;
  padding: 10rpx 24rpx;
  display: inline-block;
}

.result-meta text {
  font-size: 24rpx;
  opacity: 0.9;
}

.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 28rpx;
}

.breakdown-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.breakdown-item {
  text-align: center;
  flex: 1;
}

.breakdown-item.highlight .breakdown-val {
  color: #1677FF;
}

.breakdown-val { display: block; font-size: 32rpx; font-weight: 700; color: #1a1a1a; }
.breakdown-val.blue { color: #1677FF; }
.breakdown-val.green { color: #52C41A; }
.breakdown-eq { font-size: 32rpx; color: #ccc; padding: 0 4rpx; }

.breakdown-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.calc-subtitle {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin: 16rpx 0 10rpx;
}

.calc-formula {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  font-family: monospace;
}

.calc-result {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1677FF;
  margin-top: 6rpx;
}

.calc-result.total {
  font-size: 32rpx;
  color: #FF6B00;
}

.calc-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

.calc-note {
  margin-top: 16rpx;
  background: #FFF7E6;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
}

.calc-note text {
  font-size: 22rpx;
  color: #888;
  line-height: 1.6;
}

.progress-bar {
  height: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  display: flex;
  margin-bottom: 16rpx;
}

.progress-basic {
  background: #1677FF;
  height: 100%;
}

.progress-personal {
  background: #52C41A;
  height: 100%;
}

.progress-legend {
  display: flex;
  gap: 32rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot.blue { background: #1677FF; }
.dot.green { background: #52C41A; }

.compare-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.compare-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.compare-age {
  font-size: 26rpx;
  color: #666;
  min-width: 100rpx;
}

.compare-bar-wrap {
  flex: 1;
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.compare-bar {
  height: 100%;
  background: #d0e4ff;
  border-radius: 12rpx;
  transition: width 0.3s;
}

.compare-item.active .compare-bar {
  background: #1677FF;
}

.compare-item.active .compare-age,
.compare-item.active .compare-amount {
  color: #1677FF;
  font-weight: 600;
}

.compare-amount {
  font-size: 26rpx;
  color: #333;
  min-width: 140rpx;
  text-align: right;
}

.unlock-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid #FFD666;
}

.unlock-left {
  flex: 1;
}

.unlock-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.unlock-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.unlock-btn {
  background: #FAAD14;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  white-space: nowrap;
}

.recalc-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #1677FF;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: 2rpx solid #1677FF;
  margin-bottom: 24rpx;
}

.disclaimer {
  text-align: center;
  padding-bottom: 40rpx;
}

.disclaimer text {
  font-size: 22rpx;
  color: #bbb;
}
