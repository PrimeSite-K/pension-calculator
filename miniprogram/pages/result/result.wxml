<view class="container">
  <!-- 主结果卡片 -->
  <view class="result-card">
    <text class="result-label">预计每月养老金</text>
    <text class="result-amount">¥{{result.totalMonthly}}</text>
    <text class="result-sub">每年约 ¥{{result.totalAnnual}} · 替代率 {{result.replaceRate}}%</text>
    <view class="result-meta">
      <text>{{cityName}} · {{retireAge}}岁退休 · 缴费{{payYears}}年</text>
    </view>
  </view>

  <!-- 三项拆分 -->
  <view class="section-card">
    <text class="section-title">养老金构成</text>
    <view class="breakdown-row">
      <view class="breakdown-item highlight">
        <text class="breakdown-val">¥{{result.totalMonthly}}</text>
        <text class="breakdown-label">养老金总额</text>
      </view>
      <text class="breakdown-eq">=</text>
      <view class="breakdown-item">
        <text class="breakdown-val blue">¥{{result.basicPension}}</text>
        <text class="breakdown-label">基础养老金</text>
      </view>
      <text class="breakdown-eq">+</text>
      <view class="breakdown-item">
        <text class="breakdown-val green">¥{{result.personalPension}}</text>
        <text class="breakdown-label">个人账户养老金</text>
      </view>
    </view>
    <view class="progress-bar">
      <view class="progress-basic" style="width:{{basicRatio}}%"></view>
      <view class="progress-personal" style="width:{{personalRatio}}%"></view>
    </view>
    <view class="progress-legend">
      <view class="legend-item"><view class="dot blue"></view><text>基础养老金 {{basicRatio}}%</text></view>
      <view class="legend-item"><view class="dot green"></view><text>个人账户 {{personalRatio}}%</text></view>
    </view>
  </view>

  <!-- 计算过程 -->
  <view class="section-card">
    <text class="section-title">📋 计算过程</text>

    <text class="calc-subtitle">一、基础养老金</text>
    <text class="calc-formula">= 社平工资 × (1 + 平均缴费指数) ÷ 2 × 缴费年限 × 1%</text>
    <text class="calc-formula">= {{result.avgWage}} × (1 + {{result.avgPayIndex}}) ÷ 2 × {{result.payYears}} × 1%</text>
    <text class="calc-result">= ¥{{result.basicPension}} / 月</text>

    <view class="calc-divider"></view>

    <text class="calc-subtitle">二、个人账户养老金</text>
    <text class="calc-formula">每月个人缴费 = 缴费基数 × 8%</text>
    <text class="calc-formula">= {{result.monthlyBase}} × 8% = ¥{{result.monthlyPersonal}} / 月</text>
    <text class="calc-formula">新增累计（按6%年利率复利）= ¥{{result.newAccumulated}}</text>
    <text class="calc-formula" wx:if="{{result.existingAccount > 0}}">现有余额增值后 = ¥{{result.existingAccount}}（原始）</text>
    <text class="calc-formula">个人账户总额 = ¥{{result.personalAccount}}</text>
    <text class="calc-formula">计发月数（{{result.retireAge}}岁退休）= {{result.paymentMonths}} 个月</text>
    <text class="calc-formula">= {{result.personalAccount}} ÷ {{result.paymentMonths}}</text>
    <text class="calc-result">= ¥{{result.personalPension}} / 月</text>

    <view class="calc-divider"></view>

    <text class="calc-subtitle">三、月养老金合计</text>
    <text class="calc-formula">= 基础养老金 + 个人账户养老金</text>
    <text class="calc-formula">= {{result.basicPension}} + {{result.personalPension}}</text>
    <text class="calc-result total">= ¥{{result.totalMonthly}} / 月</text>

    <view class="calc-note">
      <text>注：社平工资取{{cityName}}2024年数据，个人账户记账利率按6%估算，实际以社保局核定为准</text>
    </view>
  </view>

  <!-- 退休年龄对比 -->
  <view class="section-card">
    <text class="section-title">不同退休年龄对比</text>
    <view class="compare-list">
      <view class="compare-item {{item.age === retireAge ? 'active' : ''}}" wx:for="{{comparison}}" wx:key="age">
        <text class="compare-age">{{item.age}}岁退休</text>
        <view class="compare-bar-wrap">
          <view class="compare-bar" style="width:{{item.barWidth}}%"></view>
        </view>
        <text class="compare-amount">¥{{item.totalMonthly}}/月</text>
      </view>
    </view>
  </view>

  <!-- 解锁详情 -->
  <view class="unlock-card" bindtap="watchAd">
    <view class="unlock-left">
      <text class="unlock-title">🎯 查看详细分析报告</text>
      <text class="unlock-desc">多缴一年多多少？断缴影响测算</text>
    </view>
    <view class="unlock-btn">看广告解锁</view>
  </view>

  <button class="recalc-btn" bindtap="recalc">重新测算</button>

  <view class="disclaimer">
    <text>本测算结果仅供参考，实际养老金以社保局核定为准</text>
  </view>
</view>
