.container {
  padding: 24rpx;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40rpx 0 32rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-top: 8rpx;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.form-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.picker-value {
  font-size: 30rpx;
  color: #1677FF;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

.radio-group {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.radio-item {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 28rpx;
  color: #666;
  background: #fafafa;
}

.radio-item.active {
  border-color: #1677FF;
  color: #1677FF;
  background: #EBF3FF;
  font-weight: 500;
}

.slider-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.slider {
  flex: 1;
}

.slider-val {
  font-size: 30rpx;
  color: #1677FF;
  font-weight: 600;
  min-width: 100rpx;
  text-align: right;
}

.wage-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.wage-preset {
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 26rpx;
  color: #666;
  background: #fafafa;
}

.wage-preset.active {
  border-color: #1677FF;
  color: #1677FF;
  background: #EBF3FF;
  font-weight: 500;
}

.wage-hint {
  font-size: 24rpx;
  color: #999;
}

.input-row {
  margin-top: 8rpx;
}

.num-input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  background: #fafafa;
  box-sizing: border-box;
}

.hint-box {
  margin-top: 16rpx;
  background: #F0F7FF;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.hint-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1677FF;
  margin-bottom: 10rpx;
}

.hint-text {
  display: block;
  font-size: 24rpx;
  color: #555;
  line-height: 1.8;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-val {
  font-size: 32rpx;
  color: #1677FF;
  font-weight: 700;
}

.calc-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 96rpx;
  background: #1677FF;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(22,119,255,0.3);
}

.disclaimer {
  text-align: center;
  margin-top: 24rpx;
  padding-bottom: 40rpx;
}

.disclaimer text {
  font-size: 22rpx;
  color: #bbb;
}
