<view class="container">
  <view class="header">
    <text class="title">退休金测算</text>
    <text class="subtitle">预估您退休后每月可领取的养老金</text>
  </view>

  <view class="form-card">
    <!-- 城市选择 -->
    <view class="form-item">
      <text class="label">参保城市</text>
      <picker mode="selector" range="{{cityNames}}" value="{{cityIndex}}" bindchange="onCityChange">
        <view class="picker-value">
          {{cityNames[cityIndex]}} <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <text class="label">性别</text>
      <view class="radio-group">
        <view class="radio-item {{gender === 'male' ? 'active' : ''}}" bindtap="setGender" data-val="male">男</view>
        <view class="radio-item {{gender === 'female' ? 'active' : ''}}" bindtap="setGender" data-val="female">女</view>
      </view>
    </view>

    <!-- 出生年份 -->
    <view class="form-item">
      <text class="label">出生年份</text>
      <view class="slider-row">
        <slider min="1960" max="2000" value="{{birthYear}}" bindchange="onBirthYearChange" activeColor="#1677FF" block-size="20" class="slider"/>
        <text class="slider-val">{{birthYear}}年</text>
      </view>
    </view>

    <!-- 开始缴费年份 -->
    <view class="form-item">
      <text class="label">开始缴费年份</text>
      <view class="slider-row">
        <slider min="1990" max="2024" value="{{startYear}}" bindchange="onStartYearChange" activeColor="#1677FF" block-size="20" class="slider"/>
        <text class="slider-val">{{startYear}}年</text>
      </view>
    </view>

    <!-- 平均缴费指数 -->
    <view class="form-item">
      <text class="label">本人平均缴费指数</text>
      <view class="input-row">
        <input class="num-input" type="digit" value="{{avgPayIndex}}" bindinput="onPayIndexInput" placeholder="请输入，如 1.02" maxlength="5"/>
      </view>
      <view class="hint-box">
        <text class="hint-title">📌 计算说明</text>
        <text class="hint-text">本人平均缴费指数 = 历年实际缴费指数之和 ÷ 实际缴费年限</text>
        <text class="hint-text">示例：实际缴费15年，历年缴费指数分别为0.6、0.8、1.0、1.2、1.5（各3年）</text>
        <text class="hint-text">总指数 = (0.6+0.8+1.0+1.2+1.5)×3 = 15.3</text>
        <text class="hint-text">平均缴费指数 = 15.3 ÷ 15 = 1.02</text>
      </view>
    </view>

    <!-- 退休年龄 -->
    <view class="form-item">
      <text class="label">退休年龄（岁）</text>
      <view class="input-row">
        <input class="num-input" type="number" value="{{retireAge}}" bindinput="onRetireAgeInput" placeholder="请输入退休年龄，如 60" maxlength="2"/>
      </view>
    </view>

    <!-- 缴费年限显示 -->
    <view class="info-row">
      <text class="info-label">预计缴费年限</text>
      <text class="info-val">{{payYears}} 年</text>
    </view>
  </view>

  <button class="calc-btn" bindtap="calculate">立即测算</button>

  <view class="disclaimer">
    <text>本测算结果仅供参考，实际养老金以社保局核定为准</text>
  </view>
</view>
