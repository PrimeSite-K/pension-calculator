<view class="container">
  <view class="form-card">
    <!-- 性别 -->
    <view class="form-item">
      <text class="label">性别</text>
      <view class="radio-group">
        <view class="radio-item {{gender === 'male' ? 'active' : ''}}" bindtap="setGender" data-val="male">男</view>
        <view class="radio-item {{gender === 'female' ? 'active' : ''}}" bindtap="setGender" data-val="female">女</view>
      </view>
    </view>

    <!-- 出生日期 -->
    <view class="form-item">
      <text class="label">出生日期</text>
      <picker mode="date" value="{{birthDate}}" start="1950-01-01" end="2000-12-31" bindchange="onBirthDateChange">
        <view class="picker-value">
          {{birthDate}} <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 工作类型：男性只有一类，女性分干部/工人 -->
    <view class="form-item" wx:if="{{gender === 'female'}}">
      <text class="label">人员类别</text>
      <view class="type-list">
        <view class="type-item {{workType === 'cadre' ? 'active' : ''}}" bindtap="setWorkType" data-val="cadre">
          <text class="type-title">干部（管理/技术岗）</text>
          <text class="type-desc">法定退休年龄：55岁</text>
        </view>
        <view class="type-item {{workType === 'worker' ? 'active' : ''}}" bindtap="setWorkType" data-val="worker">
          <text class="type-title">工人（操作/生产岗）</text>
          <text class="type-desc">法定退休年龄：50岁</text>
        </view>
      </view>
    </view>

    <view class="form-item" wx:if="{{gender === 'male'}}">
      <text class="label">人员类别</text>
      <view class="type-item active">
        <text class="type-title">普通职工</text>
        <text class="type-desc">法定退休年龄：60岁</text>
      </view>
    </view>
  </view>

  <button class="calc-btn" bindtap="calculate">计算退休年龄</button>

  <!-- 结果区域 -->
  <view class="result-card" wx:if="{{result}}">
    <view class="result-row">
      <text class="result-label">法定退休年龄</text>
      <text class="result-val">{{result.retireAge}}</text>
    </view>
    <view class="result-row">
      <text class="result-label">预计退休日期</text>
      <text class="result-val">{{result.retireDate}}</text>
    </view>
    <view class="result-row">
      <text class="result-label">距退休还有</text>
      <text class="result-val highlight">{{result.remaining}}</text>
    </view>
    <view class="result-note">
      <text>{{result.note}}</text>
    </view>
  </view>

  <view class="policy-card">
    <text class="policy-title">📋 退休年龄政策说明</text>
    <view class="policy-row"><text class="policy-dot">•</text><text class="policy-text">男性职工：原60岁，每4个月延迟1个月，最终63岁</text></view>
    <view class="policy-row"><text class="policy-dot">•</text><text class="policy-text">女性干部：原55岁，每4个月延迟1个月，最终58岁</text></view>
    <view class="policy-row"><text class="policy-dot">•</text><text class="policy-text">女性工人：原50岁，每2个月延迟1个月，最终55岁</text></view>
    <view class="policy-row"><text class="policy-dot">•</text><text class="policy-text">2025年1月起实施，原退休日期在此之前不受影响</text></view>
  </view>

  <view class="disclaimer">
    <text>本测算结果仅供参考，实际退休年龄以社保局核定为准</text>
  </view>
</view>
